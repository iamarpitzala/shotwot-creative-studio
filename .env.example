# Backend API URL
# For local dev, point directly at the local backend.
# For production (Vercel), use /api — Vercel rewrites proxy it to the backend.
VITE_API_URL=http://localhost:8000

# Firebase Web App Config
# Create a Web App in your Firebase project console and copy the config block here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
